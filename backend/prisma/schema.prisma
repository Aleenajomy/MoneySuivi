generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String         @db.VarChar(50)
  email         String         @unique
  password      String
  budgetLimit   Float          @default(0)
  currency      String         @default("INR")
  expenses      Expense[]
  budgets       Budget[]
  notifications Notification[]
  emis          EMI[]
  assets        Asset[]
  liabilities   Liability[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Expense {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String    @db.VarChar(100)
  amount         Float
  category       String
  type           String    @default("expense")
  accountType    String    @default("Cash")
  fromAccountType String?
  toAccountType   String?
  paymentMethod  String    @default("Cash")
  note           String?   @db.VarChar(500)
  expenseDate    DateTime  @default(now())
  recurring      Boolean   @default(false)
  recurringType  String?
  nextRunDate    DateTime?
  isAutoCreated  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, expenseDate])
  @@index([userId, category])
  @@index([userId, accountType])
  @@index([recurring, nextRunDate])
}

model Budget {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     String
  monthlyLimit Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, category])
}

model EMI {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                String   @db.VarChar(100)
  totalAmount          Float
  emiAmount            Float?
  totalInstallments    Int?
  paidInstallments     Int      @default(0)
  paidAmount           Float    @default(0)
  startDate            DateTime
  nextDueDate          DateTime?
  note                 String?  @db.VarChar(500)
  active               Boolean  @default(true)
  type                 String   @default("FIXED")
  interestRate         Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  payments             EMIPayment[]

  @@index([userId, active])
}

model EMIPayment {
  id          String   @id @default(uuid())
  emiId       String
  emi         EMI      @relation(fields: [emiId], references: [id], onDelete: Cascade)
  amount      Float
  paidAt      DateTime @default(now())
  note        String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([emiId])
}

model Asset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(100)
  type      String
  value     Float
  note      String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Liability {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(100)
  type      String
  value     Float
  note      String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  percentage Float    @default(0)
  message   String
  type      String   @default("warning")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}
