{
  "name": "moneysuivi-backend",
  "version": "1.0.0",
  "description": "Backend API for MoneySuivi",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "fresh": "powershell -Command \"$p = (netstat -ano | Select-String ':5000 .+LISTENING').Line.Split(' ')[-1]; if ($p) { taskkill /F /PID $p 2>$null }\" ; nodemon server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "build": "prisma generate && prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "prisma": "^6.19.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
